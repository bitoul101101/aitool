{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "AI Security & Compliance Scanner",
          "version": "19.1",
          "informationUri": "https://example.invalid/local-ai-scanner",
          "rules": [
            {
              "id": "sql_injection_direct",
              "name": "sql_injection_direct",
              "shortDescription": {
                "text": "SQL query built with an f-string passed directly to cursor.execute() — user-controlled input without parameterisation enables SQL injection; use parameterised queries with ? placeholders."
              },
              "properties": {
                "severity_label": "Sev-1 (Critical)",
                "policy_status": "CRITICAL"
              }
            },
            {
              "id": "debug_mode",
              "name": "debug_mode",
              "shortDescription": {
                "text": "Debug or verbose mode is enabled — this may expose full prompts, API keys, or internal data in logs; disable before deploying to production."
              },
              "properties": {
                "severity_label": "Sev-1 (Critical)",
                "policy_status": "CRITICAL"
              }
            },
            {
              "id": "unsafe_output_rendering",
              "name": "unsafe_output_rendering",
              "shortDescription": {
                "text": "LLM output rendered as raw HTML — without sanitisation this enables stored XSS; always escape or sanitise LLM output before rendering."
              },
              "properties": {
                "severity_label": "Sev-1 (Critical)",
                "policy_status": "CRITICAL"
              }
            },
            {
              "id": "llm_output_file_write",
              "name": "llm_output_file_write",
              "shortDescription": {
                "text": "LLM output written directly to a file without validation — an attacker could inject path traversal sequences; validate and sanitise before writing."
              },
              "properties": {
                "severity_label": "Sev-1 (Critical)",
                "policy_status": "CRITICAL"
              }
            },
            {
              "id": "cross_context_injection",
              "name": "cross_context_injection",
              "shortDescription": {
                "text": "Conversation history or session memory injected into the active prompt context without a trust boundary — a poisoned prior turn can carry instructions into future interactions (cross-context injection). Validate and sanitise stored context before reuse."
              },
              "properties": {
                "severity_label": "Sev-1 (Critical)",
                "policy_status": "CRITICAL"
              }
            },
            {
              "id": "llm_tool_no_authz",
              "name": "llm_tool_no_authz",
              "shortDescription": {
                "text": "LLM agent tool defined — verify that tool functions enforce authorization checks; without them an LLM can be manipulated into accessing arbitrary users' data (excessive agency / IDOR)."
              },
              "properties": {
                "severity_label": "Sev-1 (Critical)",
                "policy_status": "CRITICAL"
              }
            },
            {
              "id": "sql_in_tool_description",
              "name": "sql_in_tool_description",
              "shortDescription": {
                "text": "Raw SQL query in an LLM tool description — leaking query structure to the LLM enables prompt injection: an attacker can craft inputs that manipulate the query to target different records or users."
              },
              "properties": {
                "severity_label": "Sev-1 (Critical)",
                "policy_status": "CRITICAL"
              }
            },
            {
              "id": "hardcoded_credential_db",
              "name": "hardcoded_credential_db",
              "shortDescription": {
                "text": "Plaintext credentials inserted directly into the database — passwords must be hashed (bcrypt/argon2) before storage; never store or commit plaintext passwords in seed data or fixtures."
              },
              "properties": {
                "severity_label": "Sev-1 (Critical)",
                "policy_status": "CRITICAL"
              }
            },
            {
              "id": "langchain",
              "name": "langchain",
              "shortDescription": {
                "text": "LangChain framework is used — review which underlying providers are invoked and whether each is approved."
              },
              "properties": {
                "severity_label": "Sev-2 (High)",
                "policy_status": "REVIEW"
              }
            },
            {
              "id": "litellm",
              "name": "litellm",
              "shortDescription": {
                "text": "LiteLLM proxy/gateway is used — verify the routing config does not silently forward requests to unapproved providers."
              },
              "properties": {
                "severity_label": "Sev-3 (Medium)",
                "policy_status": "REVIEW"
              }
            },
            {
              "id": "model_name_in_config",
              "name": "model_name_in_config",
              "shortDescription": {
                "text": "A specific AI model name is hardcoded in a config file — move model selection to an environment variable so it can be changed without a code deployment."
              },
              "properties": {
                "severity_label": "Sev-4 (Low)",
                "policy_status": "REVIEW"
              }
            }
          ]
        }
      },
