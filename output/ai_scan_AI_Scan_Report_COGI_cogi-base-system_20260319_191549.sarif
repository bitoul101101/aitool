  "runs": [
    {
      "tool": {
        "driver": {
          "name": "AI Security & Compliance Scanner",
          "version": "19.1",
          "informationUri": "https://example.invalid/local-ai-scanner",
          "rules": [
            {
              "id": "sql_injection_risk",
              "name": "sql_injection_risk",
              "shortDescription": {
                "text": "LLM-generated SQL appears to be executed directly — use parameterised queries or a query allow-list to prevent SQL injection."
              },
              "properties": {
                "severity_label": "Sev-1 (Critical)",
                "policy_status": "CRITICAL"
              }
            },
            {
              "id": "anthropic",
              "name": "anthropic",
              "shortDescription": {
                "text": "Anthropic Claude SDK is used — ensure key is not hardcoded and usage is documented."
              },
              "properties": {
                "severity_label": "Sev-3 (Medium)",
                "policy_status": "APPROVED"
              }
            },
            {
              "id": "direct_http_ai",
              "name": "direct_http_ai",
              "shortDescription": {
                "text": "A direct HTTP call to an external AI API endpoint was found — use an SDK instead and ensure the request is authenticated securely."
              },
              "properties": {
                "severity_label": "Sev-3 (Medium)",
                "policy_status": "REVIEW"
              }
            }
          ]
        }
      },
